# trace-gate push endpoint (optional, best-effort).
# When set, trace-gate posts coverage summaries to this Tracera ingest URL.
# The value is read from the TRACE_GATE_PUSH_URL env var at runtime.
# To use: set this as a GitHub Actions secret and pass it as `push_url`:
#
#   jobs:
#     trace-gate:
#       uses: KooshaPari/phenotype-pm-core/.github/workflows/trace-gate.yml@main
#       secrets:
#         push_url: ${{ secrets.TRACE_GATE_PUSH_URL }}
#
# TRACE_GATE_PUSH_URL=https://tracera.example.com/api/v1/coverage/ingest
